VOICE_LAB_ROOT=/opt/voice-lab
GPU_HOST=
GPU_USER=root
GPU_PORT=22
GPU_SSH_KEY=
GPU_PROJECT_PATH=/opt/voice-lab
RSYNC_DELETE=false
DEFAULT_DATASET_NAME=mi_voz
DEFAULT_MODEL_NAME=mi_voz
DEFAULT_SAMPLE_RATE=40000
OUTPUT_MP3_BITRATE=192k
MAX_BATCH_JOBS=1
CPU_QUOTA=60%
MEMORY_MAX=5G
BATCH_CRON_SCHEDULE="0 2 * * *"
LOG_LEVEL=INFO

# Optional future integration path for Applio/RVC.
# RVC_ENGINE_PATH=/opt/voice-lab/vendor/applio
